{
  "dataset": {
    "repo_id": "ramen-noodels/delta_xyz_final_rgb",
    "root": null,
    "episodes": null,
    "image_transforms": {
      "enable": true,
      "max_num_transforms": 3,
      "random_order": true,
      "tfs": {
        "brightness": {
          "weight": 1.0,
          "type": "ColorJitter",
          "kwargs": {
            "brightness": [
              0.5,
              1.5
            ]
          }
        },
        "contrast": {
          "weight": 1.0,
          "type": "ColorJitter",
          "kwargs": {
            "contrast": [
              0.5,
              1.5
            ]
          }
        },
        "saturation": {
          "weight": 1.0,
          "type": "ColorJitter",
          "kwargs": {
            "saturation": [
              0.5,
              1.5
            ]
          }
        },
        "hue": {
          "weight": 1.0,
          "type": "ColorJitter",
          "kwargs": {
            "hue": [
              -0.1,
              0.1
            ]
          }
        },
        "sharpness": {
          "weight": 1.0,
          "type": "SharpnessJitter",
          "kwargs": {
            "sharpness": [
              0.5,
              1.5
            ]
          }
        }
      }
    },
    "revision": null,
    "use_imagenet_stats": false,
    "video_backend": "torchcodec"
  },
  "env": null,
  "policy": {
    "type": "diffusion",
    "n_obs_steps": 2,
    "normalization_mapping": {
      "VISUAL": "MEAN_STD",
      "STATE": "MIN_MAX",
      "ACTION": "MIN_MAX"
    },
    "input_features": {
      "observation.images.wrist_image": {
        "type": "VISUAL",
        "shape": [
          3,
          240,
          320
        ]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [
          1
        ]
      }
    },
    "output_features": {
      "action": {
        "type": "ACTION",
        "shape": [
          3
        ]
      }
    },
    "device": "cuda",
    "use_amp": false,
    "horizon": 8,
    "n_action_steps": 2,
    "drop_n_last_frames": 7,
    "vision_backbone": "resnet18",
    "crop_shape": [
      216,
      288
    ],
    "crop_is_random": true,
    "pretrained_backbone_weights": null,
    "use_group_norm": true,
    "spatial_softmax_num_keypoints": 32,
    "use_separate_rgb_encoder_per_camera": true,
    "audio_backbone": null,
    "down_dims": [
      512,
      1024,
      2048
    ],
    "kernel_size": 5,
    "n_groups": 8,
    "diffusion_step_embed_dim": 128,
    "use_film_scale_modulation": true,
    "noise_scheduler_type": "DDIM",
    "num_train_timesteps": 100,
    "beta_schedule": "squaredcos_cap_v2",
    "beta_start": 0.0001,
    "beta_end": 0.02,
    "prediction_type": "epsilon",
    "clip_sample": true,
    "clip_sample_range": 1.0,
    "num_inference_steps": null,
    "do_mask_loss_for_padding": false,
    "optimizer_lr": 0.0001,
    "optimizer_betas": [
      0.95,
      0.999
    ],
    "optimizer_eps": 1e-08,
    "optimizer_weight_decay": 1e-06,
    "scheduler_name": "cosine",
    "scheduler_warmup_steps": 500
  },
  "job_name": "autoresearch_diffusion",
  "resume": false,
  "seed": 2025,
  "num_workers": 8,
  "batch_size": 32,
  "steps": 5000,
  "eval_freq": 0,
  "log_freq": 100,
  "save_checkpoint": false,
  "save_freq": 5001,
  "use_policy_training_preset": true,
  "optimizer": {
    "type": "adam",
    "lr": 0.0001,
    "weight_decay": 1e-06,
    "grad_clip_norm": 10.0,
    "betas": [
      0.95,
      0.999
    ],
    "eps": 1e-08
  },
  "scheduler": {
    "type": "diffuser",
    "num_warmup_steps": 500,
    "name": "cosine"
  },
  "eval": {
    "n_episodes": 0,
    "batch_size": 1,
    "use_async_envs": false
  },
  "wandb": {
    "enable": false
  }
}